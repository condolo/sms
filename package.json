{
  "name": "msingi",
  "version": "4.28.0",
  "description": "Msingi — Multi-tenant SaaS School Management Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:react": "cd client && npm run dev",
    "build:react": "cd client && npm install && npm run build",
    "build": "npm run build:react",
    "seed": "node server/scripts/seed-demo.js",
    "seed:data": "node server/scripts/seed-demo-data.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "platform:health": "node scripts/platform-health.js",
    "platform:manifest": "node scripts/generate-endpoint-inventory.js",
    "platform:coverage": "node scripts/verify-rbac-coverage.js",
    "platform:release-gate": "node scripts/release-gate.js",
    "platform:release-cert": "node scripts/release-cert.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/server/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server/utils/academic-calc.js",
      "server/utils/ranking.js",
      "server/routes/academic-config.js",
      "server/middleware/tenant.js",
      "server/routes/students.js",
      "server/routes/auth.js",
      "server/routes/report-cards.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
