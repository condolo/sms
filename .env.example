# ─────────────────────────────────────────────────────────────────────────────
#  InnoLearn — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Free cluster at https://cloud.mongodb.com (M0 tier, no credit card)
# Get the string from: Atlas → Cluster → Connect → Drivers → Node.js 4.x+
# Replace <password> with your DB user's password; do NOT include < >
MONGODB_URI=mongodb+srv://innolearn_admin:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=innolearn

# ── JWT ──────────────────────────────────────────────────────────────────────
# Long random string — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Render can also auto-generate this (generateValue: true in render.yaml)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ── Platform Admin ────────────────────────────────────────────────────────────
# YOUR private key for the /platform dashboard — only YOU know this.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is what you type into the platform lock screen.
PLATFORM_ADMIN_KEY=your_platform_admin_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3005
NODE_ENV=development

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# SMTP_USER: the Gmail address that sends all system emails
# SMTP_PASS: Gmail App Password — NOT your Gmail login password.
#   Generate one at: myaccount.google.com → Security → 2-Step Verification → App passwords
#   Google displays it as "xxxx xxxx xxxx xxxx" (16 chars, 4 groups).
#   You can paste it exactly as shown — spaces are stripped automatically.
#   NEVER use your real Gmail password here.
SMTP_USER=yourapp@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# PLATFORM_EMAIL: address that receives new-school and approval alerts.
# Can be the same as SMTP_USER.
PLATFORM_EMAIL=yourapp@gmail.com

# ── App URL ───────────────────────────────────────────────────────────────────
# Production: your exact Render service URL (no trailing slash)
# Development: http://localhost:3005
APP_URL=http://localhost:3005

# ── Nightly Backup ────────────────────────────────────────────────────────────
# AES-256-GCM encryption key for backup files (REQUIRED for KDPA Section 41).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set this on Render under Environment → Add Environment Variable.
BACKUP_ENCRYPTION_KEY=

# Cloud storage (S3-compatible) — REQUIRED for production (Render filesystem is
# ephemeral and is wiped on every deploy).
#
# AWS S3:
BACKUP_S3_BUCKET=msingi-backups
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
#
# Cloudflare R2 (alternative — no egress fees):
#   BACKUP_S3_BUCKET=msingi-backups
#   BACKUP_S3_REGION=auto
#   BACKUP_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   BACKUP_S3_FORCE_PATH=true
#   AWS_ACCESS_KEY_ID=<R2 API token ID>
#   AWS_SECRET_ACCESS_KEY=<R2 API token secret>
#
# Backblaze B2 (alternative):
#   BACKUP_S3_BUCKET=msingi-backups
#   BACKUP_S3_REGION=us-west-002
#   BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
#
# DigitalOcean Spaces (alternative):
#   BACKUP_S3_BUCKET=msingi-backups
#   BACKUP_S3_REGION=nyc3
#   BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#
# Optional tuning:
# BACKUP_CRON_EXPR=0 23 * * *    # cron schedule (Africa/Nairobi). Default: 02:00 Kenya
# BACKUP_KEEP_DAYS=7             # daily files to retain per school. Default: 7
