# ─────────────────────────────────────────────────────────────────────────────
#  InnoLearn — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Free cluster at https://cloud.mongodb.com (M0 tier, no credit card)
# Get the string from: Atlas → Cluster → Connect → Drivers → Node.js 4.x+
# Replace <password> with your DB user's password; do NOT include < >
MONGODB_URI=mongodb+srv://innolearn_admin:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=innolearn

# ── JWT ──────────────────────────────────────────────────────────────────────
# Long random string — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Render can also auto-generate this (generateValue: true in render.yaml)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ── Platform Admin ────────────────────────────────────────────────────────────
# YOUR private key for the /platform dashboard — only YOU know this.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is what you type into the platform lock screen.
PLATFORM_ADMIN_KEY=your_platform_admin_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3005
NODE_ENV=development

# ── App URL ───────────────────────────────────────────────────────────────────
# Production: your Render URL, e.g. https://innolearn-ecosystem.onrender.com
# Development: http://localhost:3005
APP_URL=http://localhost:3005
